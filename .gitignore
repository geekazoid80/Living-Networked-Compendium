# ─── Private local research materials ────────────────────────────────────────
# The private/ folder structure and its README are tracked in git so contributors
# know the folder exists and how to use it. Only the CONTENTS are ignored.
private/*
!private/README.md

# ─── MkDocs build output ──────────────────────────────────────────────────────
site/

# ─── Generated handout artifacts ─────────────────────────────────────────────
# Handouts are published as GitHub Release artifacts, not committed to the repo.
# Remove this line only if you decide to track handout history in git.
handouts/versions/

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.egg
.venv/
venv/
ENV/
env/

# ─── Node.js (Marp CLI dependencies) ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ─── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/settings.json
*.code-workspace

# ─── Temporary files ──────────────────────────────────────────────────────────
*.tmp
*.temp
*.log
